<!DOCTYPE html PUBLIC "-//W3C//DTD XHTML 1.0 Transitional //EN" "http://www.w3.org/TR/xhtml1/DTD/xhtml1-transitional.dtd">
<html xmlns="http://www.w3.org/1999/xhtml">

<head>
    <meta http-equiv="Content-Type" content="text/html; ">
    <meta charset="UTF-8">
    <meta http-equiv="X-UA-Compatible" content="IE=edge">
    <meta name="viewport" content="width=device-width">
    <title>护网平台任务分享</title>
    <style type="text/css">
        body, html {
            font-family: 'Microsoft YaHei', Avenir, sans-serif;
        }

        .wrapper {
            margin: 15px auto 0 auto;
            border: 1px solid #494949;
            width: 70%;
            max-width: 800px;
        }

        .header {
            background-color: #494949;
            padding: 1.5% 0 1.5% 3.3%;
            line-height: 0;
        }

        .header_logo {
            height: auto;
            max-width: 320px;
        }

        .title {
            padding: 3% 0 3% 6%;
            color: #494949;
            font-size: 24px;
            line-height: 40px;
        }

        .divider {
            border: none;
            border-top: 2px dotted #979797;
            margin: 0px;
        }

        .content {
            margin: 3% 0;
            font-size: 16px;
        }

        .content-table {
            width: 100%;
            color: #494949;
            padding-bottom: 1%;
        }

        .form-label {
            width: 20%;
            text-align: right;
            padding-bottom: 1.5%;
        }

        .form-content {
            padding-left: 3%;
            padding-bottom: 1.5%;
        }

        .advice {
            margin-bottom: 1%;
        }

        .advice-table {
            margin-bottom: 1%;
            border-collapse: collapse;
            border: 1px solid #d7dbe0;
            width: 100%;
            font-size: 14px;
        }

        .advice-cell {
            border: 1px solid #d7dbe0;
        }

        .footer {
            background-color: #494949;
            color: #fff;
            padding: 0.9% 0 0.9% 3.1%;
            font-size: 12px;
            line-height: 19px;
        }

        .footer a {
            color: #fff;
        }

        .copyright {
            display: block;
            margin-top: 1%;
        }
    </style>
</head>

<body>
<div class="wrapper">
    <div class="header">
        <img class="header_logo" src="data:image/png;base64," alt="">
    </div>
    <div class="layout">
        <div class="title">
            任务详情
        </div>
        <hr class="divider"/>
        <div class="content">
            <table class="content-table">
                <tbody>
                <tr>
                    <td class="form-label">任务名称:</td>
                    <td class="form-content">${taskName}</td>
                </tr>
                <tr>
                    <td class="form-label">责任人:</td>
                    <td class="form-content">${responsible}</td>
                </tr>
                <tr>
                    <td class="form-label">到期时间:</td>
                    <td class="form-content">${endTime}</td>
                </tr>
                <tr>
                    <td class="form-label">优先级:</td>
                    <td class="form-content">${priority}</td>
                </tr>
                <tr>
                    <td class="form-label">风险:</td>
                    <td class="form-content">${risk}</td>
                </tr>
                <tr>
                    <td class="form-label">进度:</td>
                    <td class="form-content">${schedule}</td>
                </tr>  
				<tr>
                    <td class="form-label">状态:</td>
                    <td class="form-content">${state}</td>
                </tr>				
                <tr>
                    <td class="form-label">链接:</td>
                    <td class="form-content">
                        <a href=${url} target="_blank">${url}</a>
                    </td>
                </tr>
                </tbody>
            </table>
        </div>
    </div>
    <div class="footer">
        <span class="business_txt"> 
            <br class="addr_txt"> 
            <br class="tel_txt"> 
            <br class="mail_txt"> </span><br>
        <span class="copyright"> </span>
    </div>
</div>
</body>
</html>